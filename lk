#!/usr/bin/env python3
import argparse
import signal
import sys
import time
import threading
import ctypes
import ctypes.util
import os
import subprocess
import re

# Config file path to store the default keybind
CONFIG_PATH = os.path.expanduser("~/.lk_config")

# 1. Load macOS Native C Libraries via ctypes
cg_path = ctypes.util.find_library('CoreGraphics')
cf_path = ctypes.util.find_library('CoreFoundation')

if not cg_path or not cf_path:
    print("Error: This script must be run on macOS.")
    sys.exit(1)

cg = ctypes.cdll.LoadLibrary(cg_path)
cf = ctypes.cdll.LoadLibrary(cf_path)

# 2. Define Constants
kCGSessionEventTap = 1
kCGHeadInsertEventTap = 0
kCGEventTapOptionDefault = 0

# Keyboard Event Types
kCGEventKeyDown = 10
kCGEventKeyUp = 11
kCGKeyboardEventKeycode = 9

# Mouse & Trackpad Event Types
kCGEventLeftMouseDown = 1
kCGEventLeftMouseUp = 2
kCGEventRightMouseDown = 3
kCGEventRightMouseUp = 4
kCGEventMouseMoved = 5
kCGEventLeftMouseDragged = 6
kCGEventRightMouseDragged = 7
kCGEventScrollWheel = 22
kCGEventOtherMouseDown = 25
kCGEventOtherMouseUp = 26
kCGEventOtherMouseDragged = 27
kCGEventGesture = 29
kCGEventMagnify = 30
kCGEventSwipe = 31
kCGEventRotate = 32

ALL_MOUSE_EVENTS = {
    kCGEventLeftMouseDown, kCGEventLeftMouseUp,
    kCGEventRightMouseDown, kCGEventRightMouseUp,
    kCGEventMouseMoved,
    kCGEventLeftMouseDragged, kCGEventRightMouseDragged,
    kCGEventOtherMouseDown, kCGEventOtherMouseUp,
    kCGEventOtherMouseDragged,
    kCGEventScrollWheel, kCGEventGesture,
    kCGEventMagnify, kCGEventSwipe, kCGEventRotate
}

kCGEventFlagMaskControl = 1 << 18
kCGEventFlagMaskShift = 1 << 17
kCGEventFlagMaskAlternate = 1 << 19
kCGEventFlagMaskCommand = 1 << 20

ALL_MODIFIER_MASK = (
    kCGEventFlagMaskControl | kCGEventFlagMaskShift |
    kCGEventFlagMaskAlternate | kCGEventFlagMaskCommand
)

MODIFIER_KEY_CODES = {0x38, 0x3C, 0x3B, 0x3E, 0x3A, 0x3D, 0x37, 0x36, 0x39, 0x33}

KEY_MAP = {
    'a': 0x00, 'b': 0x0B, 'c': 0x08, 'd': 0x02, 'e': 0x0E, 'f': 0x03,
    'g': 0x05, 'h': 0x04, 'i': 0x22, 'j': 0x26, 'k': 0x28, 'l': 0x25,
    'm': 0x2E, 'n': 0x2D, 'o': 0x1F, 'p': 0x23, 'q': 0x0C, 'r': 0x0F,
    's': 0x01, 't': 0x11, 'u': 0x20, 'v': 0x09, 'w': 0x0D, 'x': 0x07,
    'y': 0x10, 'z': 0x06,
    '0': 0x1D, '1': 0x12, '2': 0x13, '3': 0x14, '4': 0x15, '5': 0x17,
    '6': 0x16, '7': 0x1A, '8': 0x1C, '9': 0x19,
    'esc': 0x35, 'space': 0x31, 'return': 0x24, 'tab': 0x30, 'delete': 0x33
}

MOD_MAP = {
    'ctrl': kCGEventFlagMaskControl,
    'control': kCGEventFlagMaskControl,
    'shift': kCGEventFlagMaskShift,
    'alt': kCGEventFlagMaskAlternate,
    'option': kCGEventFlagMaskAlternate,
    'opt': kCGEventFlagMaskAlternate,
    'cmd': kCGEventFlagMaskCommand,
    'command': kCGEventFlagMaskCommand
}

# 3. Define C Function Signatures & Types
CGEventTapCallBack = ctypes.CFUNCTYPE(ctypes.c_void_p, ctypes.c_void_p, ctypes.c_uint32, ctypes.c_void_p, ctypes.c_void_p)

cg.CGEventTapCreate.restype = ctypes.c_void_p
cg.CGEventTapCreate.argtypes = [
    ctypes.c_uint32, ctypes.c_uint32, ctypes.c_uint32,
    ctypes.c_uint64, CGEventTapCallBack, ctypes.c_void_p
]

cg.CGEventGetIntegerValueField.restype = ctypes.c_int64
cg.CGEventGetIntegerValueField.argtypes = [ctypes.c_void_p, ctypes.c_uint32]

cg.CGEventGetFlags.restype = ctypes.c_uint64
cg.CGEventGetFlags.argtypes = [ctypes.c_void_p]

cg.CGEventTapEnable.restype = None
cg.CGEventTapEnable.argtypes = [ctypes.c_void_p, ctypes.c_int]

cf.CFMachPortCreateRunLoopSource.restype = ctypes.c_void_p
cf.CFMachPortCreateRunLoopSource.argtypes = [ctypes.c_void_p, ctypes.c_void_p, ctypes.c_int]

cf.CFRunLoopGetMain.restype = ctypes.c_void_p
cf.CFRunLoopGetMain.argtypes = []

cf.CFRunLoopAddSource.restype = None
cf.CFRunLoopAddSource.argtypes = [ctypes.c_void_p, ctypes.c_void_p, ctypes.c_void_p]

kCFRunLoopCommonModes = ctypes.c_void_p.in_dll(cf, "kCFRunLoopCommonModes")

cf.CFRunLoopRun.restype = None
cf.CFRunLoopRun.argtypes = []

cf.CFRunLoopStop.restype = None
cf.CFRunLoopStop.argtypes = [ctypes.c_void_p]


def parse_duration(duration_str):
    """
    Parses duration strings like '5', '10s', '2m', '1h'.
    Returns total seconds as an integer.
    """
    
    # Regex: Start with one or more digits, optionally followed by s, m, or h. Case-insensitive.
    match = re.match(r"^(\d+)([smh]?)$", duration_str.lower())
    if not match:
        raise ValueError("Invalid duration format. Must be a positive integer optionally followed by 's', 'm', or 'h'.")

    num_str, suffix = match.groups()
    num = int(num_str)

    if num <= 0:
        raise ValueError("Duration must be a positive integer (greater than 0).")

    if suffix == 'm':
        return num * 60
    elif suffix == 'h':
        return num * 3600
    else:  # 's' or empty string
        return num


def parse_keybind(bind_str):
    parts = bind_str.lower().replace(" ", "").split('+')
    mod_mask = 0
    target_keycode = None

    for part in parts:
        if part in MOD_MAP:
            mod_mask |= MOD_MAP[part]
        elif part in KEY_MAP:
            if target_keycode is not None:
                raise ValueError("Only one non-modifier key is allowed.")
            target_keycode = KEY_MAP[part]
        else:
            raise ValueError(f"Unknown key or modifier: '{part}'")

    if target_keycode is None:
        raise ValueError("Must include exactly one regular key (e.g., 'u').")

    return mod_mask, target_keycode


def check_permissions():
    try:
        app_serv_path = ctypes.util.find_library('ApplicationServices')
        if not app_serv_path:
            return True
        app_serv = ctypes.cdll.LoadLibrary(app_serv_path)
        app_serv.AXIsProcessTrustedWithOptions.restype = ctypes.c_bool
        return app_serv.AXIsProcessTrustedWithOptions(None)
    except Exception:
        return True


def get_saved_default_key():
    try:
        if os.path.exists(CONFIG_PATH):
            with open(CONFIG_PATH, 'r') as f:
                key = f.read().strip()
                if key:
                    return key
    except Exception:
        pass
    return "ctrl+u"


def set_saved_default_key(key_str):
    try:
        with open(CONFIG_PATH, 'w') as f:
            f.write(key_str.strip().lower())
    except Exception as e:
        print(f"Error saving default key: {e}")
        sys.exit(1)


# 4. Main Logic
class InputLocker:
    def __init__(self, duration: int, mod_mask: int, keycode: int, bind_str: str, lock_everything: bool):
        self.duration = duration
        self.should_exit = False
        self.tap = None
        self.source = None
        self.start_time = None
        self.required_mods = mod_mask
        self.required_keycode = keycode
        self.bind_str = bind_str
        self.lock_everything = lock_everything
        self._callback = None

    def _event_callback(self, proxy, event_type, event, refcon):
        if event_type in (kCGEventKeyDown, kCGEventKeyUp):
            keycode = cg.CGEventGetIntegerValueField(event, kCGKeyboardEventKeycode)

            if keycode in MODIFIER_KEY_CODES:
                return event

            if event_type == kCGEventKeyDown:
                flags = cg.CGEventGetFlags(event)

                if keycode == self.required_keycode and (flags & ALL_MODIFIER_MASK) == self.required_mods:
                    self.should_exit = True
                    cf.CFRunLoopStop(cf.CFRunLoopGetMain())
                    return event

            return None

        if self.lock_everything and event_type in ALL_MOUSE_EVENTS:
            return None

        return event

    def _timer_thread(self):
        while not self.should_exit and self.start_time is not None:
            elapsed = time.time() - self.start_time
            if elapsed >= self.duration:
                cf.CFRunLoopStop(cf.CFRunLoopGetMain())
                return
            time.sleep(0.1)

    def run(self):
        self._callback = CGEventTapCallBack(self._event_callback)

        event_mask = (1 << kCGEventKeyDown) | (1 << kCGEventKeyUp)

        if self.lock_everything:
            for evt_type in ALL_MOUSE_EVENTS:
                event_mask |= (1 << evt_type)

        self.tap = cg.CGEventTapCreate(
            kCGSessionEventTap, kCGHeadInsertEventTap, kCGEventTapOptionDefault,
            event_mask, self._callback, None
        )

        if not self.tap:
            sys.exit(1)

        self.start_time = time.time()
        self.source = cf.CFMachPortCreateRunLoopSource(None, self.tap, 0)
        cf.CFRunLoopAddSource(cf.CFRunLoopGetMain(), self.source, kCFRunLoopCommonModes)
        cg.CGEventTapEnable(self.tap, True)

        timer = threading.Thread(target=self._timer_thread, daemon=True)
        timer.start()

        cf.CFRunLoopRun()

        cg.CGEventTapEnable(self.tap, False)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Lock keyboard (and optionally all mouse/trackpad) input on macOS",
        epilog=(
            "Safety: Press your custom kill switch at any time to unlock early.\n"
            "Requires: macOS Accessibility permissions."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )

    # Duration is now a string so we can parse suffixes
    parser.add_argument(
        "duration", type=str, nargs="?", default=None,
        help="Duration to lock (e.g., 5, 10s, 2m, 1h). Must be a positive integer"
    )
    parser.add_argument(
        "-k", "--set-key", metavar="KEY",
        help="Keybind to unlock for this run only (temporarily overrides default)"
    )
    
    parser.add_argument(
        "-d", "--default", metavar="KEY",
        help="Permanently set a new default keybind"
    )
    
    parser.add_argument(
        "-e", "--everything", action="store_true",
        help="Lock keyboard, mouse clicks and trackpad gestures"
    )
    
    parser.add_argument(
        "-c", "--close-terminal", action="store_true", 
        help="Close the terminal window immediately after launching the lock"
    )

    parser.add_argument("--daemon-run", action="store_true", help=argparse.SUPPRESS)

    args = parser.parse_args()

    # --- SET DEFAULT MODE ---
    if args.default:
        try:
            parse_keybind(args.default)
            set_saved_default_key(args.default)
            print(f"  Success! Default kill switch permanently set to: {args.default}")
            print(f"  (Saved to {CONFIG_PATH})")
            sys.exit(0)
        except ValueError as e:
            print(f"Error parsing new default keybind: {e}")
            print("Supported modifiers: ctrl, shift, alt/option, cmd/command")
            print("Supported keys: a-z, 0-9, esc, space, return, tab, delete")
            sys.exit(1)

    # --- NORMAL RUN MODE ---
    if not args.duration:
        print("Error: Duration is required.")
        print("Usage: lk <duration> [-c] [-e] [-k 'cmd+q']")
        print("       lk -d 'cmd+q'  (to set default keybind)")
        print("Duration formats: 5 (5 seconds), 5s (5 seconds), 2m (2 minutes), 1h (1 hours)")
        sys.exit(1)

    # Parse the duration string into total seconds
    try:
        duration_secs = parse_duration(args.duration)
    except ValueError as e:
        print(f"Error: {e}")
        sys.exit(1)

    # Determine which keybind to use
    active_key_str = args.set_key if args.set_key else get_saved_default_key()

    try:
        mod_mask, keycode = parse_keybind(active_key_str)
    except ValueError as e:
        print(f"Error parsing keybind '{active_key_str}': {e}")
        print("Run: lk -d 'ctrl+u' to reset your default.")
        sys.exit(1)

    # --- DAEMON MODE ---
    if args.daemon_run:
        signal.signal(signal.SIGHUP, signal.SIG_IGN)
        signal.signal(signal.SIGINT, signal.SIG_IGN)

        devnull_r = open(os.devnull, 'r')
        devnull_w = open(os.devnull, 'a+')
        os.dup2(devnull_r.fileno(), sys.stdin.fileno())
        os.dup2(devnull_w.fileno(), sys.stdout.fileno())
        os.dup2(devnull_w.fileno(), sys.stderr.fileno())

        locker = InputLocker(
            duration=duration_secs,
            mod_mask=mod_mask,
            keycode=keycode,
            bind_str=active_key_str,
            lock_everything=args.everything
        )
        locker.run()
        sys.exit(0)

    # --- PARENT MODE ---
    if not check_permissions():
        print("\n  ERROR: Missing Accessibility permissions!")
        print("\n   To grant permissions:")
        print("   1. Open: System Settings > Privacy & Security > Accessibility")
        print("   2. Add your terminal app (or VSCode/others if you're using VSCode's terminal or any other terminal) to the list")
        print("   3. Make sure it's toggled ON")
        print("   4. Run this program again")
        sys.exit(1)

    locked_devices = "Keyboard"
    if args.everything:
        locked_devices = "Keyboard, Mouse Click & Trackpad"

    print(f"  {locked_devices} locked in background for {args.duration} ({duration_secs} seconds)")

    script_path = os.path.realpath(__file__)
    # Pass the pre-calculated seconds to the daemon to avoid double-parsing
    cmd = [sys.executable, script_path, "--daemon-run", str(duration_secs), "-k", active_key_str]

    if args.everything:
        cmd.append("--everything")
    
    if args.close_terminal:
        cmd.append("--close-terminal")

    subprocess.Popen(
        cmd,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        stdin=subprocess.DEVNULL,
        start_new_session=True
    )
    
    # Close the terminal window immediately after launching the lock
    if args.close_terminal:
        try:
            ppid = os.getppid() # get the parent process id (the terminal)
            # Use 'kill' command to terminate the parent process
            subprocess.run(['kill', '-9', str(ppid)], check=True)
        except Exception as e:
            print(f"Error closing terminal: {e}")

    sys.exit(0)
